# --------------------------------------------------------------------------
# iac-tfm prod env — terraform.tfvars.example
# Copy to terraform.tfvars and customize.
# --------------------------------------------------------------------------

# AWS
aws_region   = "ap-southeast-2"
project_name = "iac-tfm"

# Env
environment_name = "prod"
role_name_prefix = "iac-prod"
oidc_environment = "production"   # matches GitHub Environment name

# Domain
primary_domain = "example.com"

# Tags
owner = "platform-team"

# Alerts
# alert_email = "ops@example.com"

# Cloudflare Turnstile (get from https://dash.cloudflare.com → Turnstile)
# turnstile_secret = "0x1234567890abcdef..."

# Sites — one block per site. Key is a short identifier.
# After editing, drop the underscore prefix on the corresponding
# envs/prod/sites/_<key>.tf file to actually deploy.
sites = {
  example-com = {
    domain              = "example.com"
    enable_www_redirect = true
  }

  blogs-example-com = {
    domain              = "blogs.example.com"
    enable_www_redirect = false
  }

  app-example-com = {
    domain              = "app.example.com"
    enable_www_redirect = false
  }
}

# Team members (leave empty to skip user creation)
# team_members = [
#   { name = "alice", role = "admin", email = "alice@example.com" },
# ]

# GitHub OIDC — REPLACE the placeholders below before applying
github_org  = "YOUR_ORG"
github_repo = "iac-tfm"
